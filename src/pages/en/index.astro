---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
const posts = (await getCollection('posts_en', p => p.data.lang === 'en' && !p.data.draft))
  .sort((a,b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout>
    <blockquote>
        Moscow’s news reports fall into three categories: “true,” “probably true,” and “untrue.”
        The first category includes the time signals, the second the weather forecasts, and the third everything else.
        — <i>Anekdot</i>
    </blockquote>
    <h2>最近の記事</h2>
    <ul class="recent">
        {
            posts.map((p) => (
                <li class="card">
                    <a class="link" href={`/${p.slug}`}>
                        <div class="card-content">
                            <h3 class="title">{p.data.title}</h3>
                            <p class="date">{p.data.date.toISOString().slice(0, 10)}</p>
                            <p class="summary">{p.body}</p>
                        </div>
                    </a>
                </li>
            ))
        }
    </ul>
</Layout>

<style>
    .recent {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        list-style: none;
        padding: 0;
        margin 0;
        gap: 1rem;
    }
    .card {
        display: flex;
        height: 100%;
        width: 100%;
        overflow: hidden;
        flex-direction: column;
        border: 1px solid var(--white);
        aspect-ratio: 1 / 1;
    }
    .link {
        display: block;
        height: 100%;
        text-decoration: none;
        padding: 1rem;
    }
    :root[data-theme="light"] .link:hover {
        border: 1px solid var(--pink);
    }
    .title {
        margin: 0 0 0.5rem;
        font-size: 1.5rem;
        line-height: 2rem;
        overflow: hidden;
        max-height: 4rem;
        text-overflow: ellipsis;
                    display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
    }
    .date {
        text-indent: 0;
        margin: 0 0 0.5rem;
    }
    .summary {
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 12;
        -webkit-box-orient: vertical;
    }
    
    @media screen and (max-width: 640px) {
        .recent {
            grid-template-columns: repeat(1, 1fr);
        }
        .card {
            aspect-ratio: unset;
        }
    .summary {
        -webkit-line-clamp: 8;
    }
    }
</style>
