---
interface Props {
  postSlug: string;
}
const { postSlug } = Astro.props;

const contractAddress = "0x694790a0A09b60103C616003B8404b141557F4DA";
const rpcUrl = "https://sepolia.base.org";
const relayerUrl = "https://relayer.kristina3731.workers.dev";
const deployBlock = "38990704";
---

<section class="comments" id="comments"
  data-post-slug={postSlug}
  data-contract={contractAddress}
  data-rpc={rpcUrl}
  data-relayer={relayerUrl}
  data-deploy-block={deployBlock}
>
  <h2>Comments</h2>
  <div id="comment-list" class="comment-list">
    <p class="loading">Loading comments…</p>
  </div>

  <div id="comment-form" class="comment-form">
    <div id="wallet-section">
      <button id="connect-wallet" type="button">Connect Wallet</button>
    </div>
    <div id="form-fields" style="display:none;">
      <div class="form-row">
        <input type="text" id="username-input" placeholder="Username" maxlength="64" />
        <span id="wallet-address"></span>
      </div>
      <textarea id="content-input" placeholder="Write a comment…" maxlength="5120" rows="4"></textarea>
      <div class="form-row">
        <button id="submit-comment" type="button">Post Comment</button>
        <span id="form-status"></span>
      </div>
    </div>
  </div>
</section>

<script>
  import { createPublicClient, http, keccak256, toHex, encodePacked, type Hex } from "viem";
  import { baseSepolia } from "viem/chains";

  const golosAbi = [
    {
      type: "event" as const,
      name: "CommentPosted" as const,
      inputs: [
        { name: "postId", type: "bytes32" as const, indexed: true },
        { name: "author", type: "address" as const, indexed: true },
        { name: "username", type: "string" as const, indexed: false },
        { name: "ensName", type: "string" as const, indexed: false },
        { name: "content", type: "string" as const, indexed: false },
        { name: "timestamp", type: "uint256" as const, indexed: false },
      ],
      anonymous: false,
    },
  ] as const;

  const section = document.getElementById("comments")!;
  const postSlug = section.dataset.postSlug!;
  const contractAddress = section.dataset.contract! as Hex;
  const rpcUrl = section.dataset.rpc!;
  const relayerUrl = section.dataset.relayer!;
  const deployBlock = BigInt(section.dataset.deployBlock!);

  const postId = keccak256(toHex(postSlug));

  const publicClient = createPublicClient({
    chain: baseSepolia,
    transport: http(rpcUrl),
  });

  type Comment = {
    author: string;
    username: string;
    ensName: string;
    content: string;
    timestamp: number;
  };

  // --- Load comments ---

  async function loadComments(): Promise<Comment[]> {
    const logs = await publicClient.getContractEvents({
      address: contractAddress,
      abi: golosAbi,
      eventName: "CommentPosted",
      args: { postId },
      fromBlock: deployBlock,
    });

    return logs.map((log) => ({
      author: log.args.author!,
      username: log.args.username!,
      ensName: log.args.ensName!,
      content: log.args.content!,
      timestamp: Number(log.args.timestamp!),
    }));
  }

  function renderComments(comments: Comment[]) {
    const list = document.getElementById("comment-list")!;
    if (comments.length === 0) {
      list.innerHTML = "<p class='no-comments'>No comments yet.</p>";
      return;
    }
    list.innerHTML = comments
      .map((c) => {
        const date = new Date(c.timestamp * 1000).toISOString().slice(0, 16).replace("T", " ");
        const shortAddr = c.author.slice(0, 6) + "…" + c.author.slice(-4);
        const ensLine = c.ensName ? `<span class="author-ens">${escapeHtml(c.ensName)}</span> ` : "";
        return `<div class="comment">
          <div class="comment-header">
            <div class="comment-author-block">
              <span class="comment-author">${escapeHtml(c.username)}</span>
              <span class="author-meta">${ensLine}<span class="author-addr">${shortAddr}</span></span>
            </div>
            <span class="comment-date">${date}</span>
          </div>
          <div class="comment-body">${escapeHtml(c.content)}</div>
        </div>`;
      })
      .join("");
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  loadComments().then(renderComments).catch((e) => {
    console.error("Failed to load comments:", e);
    document.getElementById("comment-list")!.innerHTML =
      "<p class='error'>Failed to load comments.</p>";
  });

  // --- Wallet connection ---

  const connectBtn = document.getElementById("connect-wallet") as HTMLButtonElement;
  const walletAddr = document.getElementById("wallet-address")!;
  const formFields = document.getElementById("form-fields")!;
  const submitBtn = document.getElementById("submit-comment") as HTMLButtonElement;
  const usernameInput = document.getElementById("username-input") as HTMLInputElement;
  const contentInput = document.getElementById("content-input") as HTMLTextAreaElement;
  const formStatus = document.getElementById("form-status")!;

  let connectedAddress: Hex | null = null;

  // Restore saved username
  const savedUsername = localStorage.getItem("golos:username");
  if (savedUsername) usernameInput.value = savedUsername;

  connectBtn.addEventListener("click", async () => {
    const ethereum = (window as any).ethereum;
    if (!ethereum) {
      alert("Please install a wallet (e.g. MetaMask)");
      return;
    }

    try {
      const accounts = await ethereum.request({ method: "eth_requestAccounts" });
      connectedAddress = accounts[0] as Hex;
      walletAddr.textContent = connectedAddress!.slice(0, 6) + "…" + connectedAddress!.slice(-4);
      connectBtn.style.display = "none";
      formFields.style.display = "block";
    } catch (e) {
      console.error("Wallet connection failed:", e);
    }
  });

  // --- Submit comment ---

  submitBtn.addEventListener("click", async () => {
    const ethereum = (window as any).ethereum;
    if (!connectedAddress || !ethereum) return;

    const username = usernameInput.value.trim();
    const content = contentInput.value.trim();
    if (!username) { formStatus.textContent = "Username is required"; return; }
    if (!content) { formStatus.textContent = "Comment is required"; return; }

    submitBtn.disabled = true;
    formStatus.textContent = "Signing…";

    try {
      const messageHash = keccak256(
        encodePacked(
          ["address", "bytes32", "string", "string"],
          [connectedAddress, postId, username, content],
        ),
      );

      // EIP-191 personal_sign
      const signature = await ethereum.request({
        method: "personal_sign",
        params: [messageHash, connectedAddress],
      });

      formStatus.textContent = "Submitting…";

      const res = await fetch(`${relayerUrl}/comment`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          author: connectedAddress,
          postSlug,
          username,
          content,
          signature,
        }),
      });

      const data = await res.json();
      if (res.ok) {
        formStatus.textContent = "Comment posted! Waiting for confirmation…";
        contentInput.value = "";
        localStorage.setItem("golos:username", username);
        // Reload comments after a short delay for tx confirmation
        setTimeout(async () => {
          const comments = await loadComments();
          renderComments(comments);
          formStatus.textContent = "";
        }, 5000);
      } else {
        formStatus.textContent = `Error: ${data.error}`;
      }
    } catch (e: any) {
      formStatus.textContent = `Error: ${e.message ?? "Unknown error"}`;
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .comments {
    margin-top: 3rem;
    border-top: 1px solid var(--gray);
    padding-top: 1.5rem;
  }
  .comments h2 {
    font-size: 1.5rem;
    font-weight: 400;
    border: 0 solid var(--pink);
    border-left-width: 3px;
    padding: 0.5rem 3px;
    margin: 0 0 1rem;
  }
  .comment-list {
    margin-bottom: 2rem;
  }
  .comment {
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--clear-black);
  }
  .comment-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.3rem;
  }
  .comment-author-block {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .comment-author {
    font-weight: 700;
  }
  .author-meta {
    font-size: 0.75rem;
    color: var(--gray);
  }
  .author-ens {
    color: var(--gray);
  }
  .author-addr {
    font-family: monospace;
    color: var(--gray);
  }
  .comment-date {
    color: var(--gray);
    font-size: 0.85rem;
  }
  .comment-body {
    white-space: pre-wrap;
    line-height: 1.5;
    padding: 0;
  }
  .no-comments, .loading, .error {
    color: var(--gray);
    text-indent: 0;
  }
  .comment-form {
    margin-top: 1rem;
  }
  #form-fields {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .form-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  #wallet-address {
    color: var(--gray);
    font-size: 0.85rem;
  }
  #username-input, #content-input {
    background: var(--dark);
    color: var(--white);
    border: 1px solid var(--gray);
    border-radius: 0;
    padding: 0.5rem;
    font-family: inherit;
    font-size: inherit;
    resize: vertical;
    outline: none;
    box-sizing: border-box;
    width: 100%;
  }
  #username-input:focus, #content-input:focus {
    border-color: var(--pink);
  }
  #username-input {
    max-width: 16rem;
    resize: none;
  }
  #content-input {
    text-indent: 0;
  }
  button {
    background: var(--pink);
    color: var(--white);
    border: none;
    border-radius: 0;
    padding: 0.5rem 1.2rem;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    transition: var(--ease);
    align-self: flex-start;
  }
  button:hover {
    background: var(--peach);
    color: var(--white);
  }
  button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  #form-status {
    color: var(--gray);
    font-size: 0.85rem;
    text-indent: 0;
  }
</style>
