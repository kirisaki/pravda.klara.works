---
import Comments from "./Comments";

interface Props {
  postSlug: string;
}
const { postSlug } = Astro.props;
---

<Comments client:only="preact" postSlug={postSlug} />

<style is:global>
  .comments {
    margin-top: 3rem;
    border-top: 1px solid var(--gray);
    padding-top: 1.5rem;
  }
  .comments h2 {
    font-size: 1.5rem;
    font-weight: 400;
    border: 0 solid var(--pink);
    border-left-width: 3px;
    padding: 0.5rem 3px;
    margin: 0 0 1rem;
  }
  .comment-list {
    margin-bottom: 2rem;
  }
  .comment {
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--clear-black);
  }
  .comment-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.3rem;
  }
  .comment-author-line {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .comment-author {
    font-weight: 700;
  }
  .author-ens {
    font-size: 0.8rem;
    color: var(--gray);
  }
  .author-addr {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--gray);
  }
  .comment-date {
    color: var(--gray);
    font-size: 0.85rem;
  }
  .comment-body {
    white-space: pre-wrap;
    line-height: 1.5;
    padding: 0;
  }
  .comment-status {
    color: var(--gray);
    text-indent: 0;
  }
  .comment-form {
    margin-top: 1rem;
  }
  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .form-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .wallet-address {
    color: var(--gray);
    font-size: 0.85rem;
  }
  .comments input,
  .comments textarea {
    background: var(--dark);
    color: var(--white);
    border: 1px solid var(--gray);
    border-radius: 0;
    padding: 0.5rem;
    font-family: inherit;
    font-size: inherit;
    resize: vertical;
    outline: none;
    box-sizing: border-box;
    width: 100%;
  }
  .comments input:focus,
  .comments textarea:focus {
    border-color: var(--pink);
  }
  .comments input {
    max-width: 16rem;
    resize: none;
  }
  .comments textarea {
    text-indent: 0;
  }
  .comments button {
    background: var(--pink);
    color: var(--white);
    border: none;
    border-radius: 0;
    padding: 0.5rem 1.2rem;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    transition: var(--ease);
    align-self: flex-start;
  }
  .comments button:hover {
    background: var(--peach);
    color: var(--white);
  }
  .comments button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .form-status {
    color: var(--white);
    font-size: 0.85rem;
    text-indent: 0;
  }
</style>
